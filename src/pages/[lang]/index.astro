---
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Hero from "@components/Hero.astro";
import Footer from "@components/Footer.astro";
import { useTranslations } from "@i18n/utils";

export function getStaticPaths() {
    return [{ params: { lang: 'es' } }, { params: { lang: 'en' } }];
}

const { lang } = Astro.params;
const translation = useTranslations(lang as 'es' | 'en');
---

<Layout
	title={translation("pageTitle")}
	description={translation("pageDescription")}
	lang={lang}
	url={`https://goncar.vercel.app/${lang}`}
	alternates={{
		en: "https://goncar.vercel.app/en",
		es: "https://goncar.vercel.app/es",
	}}
>
	<Header />
	<Hero />
	<section>
		<h1>{translation("home.title")}</h1>
		<div>
			<ul class="link-cards">
				<li class="link-cards">
					<svg height="800px" width="800px" viewBox="0 0 512 512">
						<path fill="#e34f26" d="M71 460L30 0h451l-41 460-185 52"></path>
						<path fill="#ef652a" d="M256 472l149-41 35-394H256"></path>
						<path fill="#ebebeb" d="M256 208h-75l-5-58h80V94H114l15 171h127zm-1 147l-63-17-4-45h-56l7 89 116 32z"></path>
						<path fill="#ffffff" d="M255 208v57h70l-7 73-63 17v59l116-32 16-174zm0-114v56h137l5-56z"></path>
					</svg>
					<h2>HTML</h2>
				</li>
			</ul>
			<ul class="link-cards">
				<li class="link-cards">
					<svg height="800px" width="800px" viewBox="0 0 512 512">
						<path fill="#264de4" d="M72 460L30 0h451l-41 460-184 52"></path>
						<path fill="#2965f1" d="M256 37V472l149-41 35-394"></path>
						<path fill="#ebebeb" d="m114 94h142v56H119m5 58h132v57H129m3 28h56l4 45 64 17v59L139 382"></path>
						<path fill="#ffffff" d="m256 208v57h69l-7 73-62 17v59l115-32 26-288H256v56h80l-5.5 58Z"></path>
					</svg>
					<h2>CSS</h2>
				</li>
			</ul>
			<ul class="link-cards">
				<li class="link-cards">
					<svg width="800px" height="800px" viewBox="0 0 32 32">
						<path d="M26.11,17.572a5.8,5.8,0,0,0-2.537.588,5.345,5.345,0,0,1-.568-1.314,3.53,3.53,0,0,1-.051-1.1,9.811,9.811,0,0,1,.332-1.192c-.005-.051-.061-.292-.624-.3s-1.048.107-1.1.256a6.171,6.171,0,0,0-.235.834,19.686,19.686,0,0,1-1.713,3.294,3.186,3.186,0,0,1-.44-2.066,9.811,9.811,0,0,1,.332-1.192c-.005-.051-.061-.292-.624-.3s-1.048.107-1.1.256-.118.5-.235.834-1.483,3.386-1.841,4.173c-.184.4-.343.726-.455.946h0a.233.233,0,0,1-.02.041c-.1.189-.153.292-.153.292v.005c-.077.138-.159.266-.2.266a1.711,1.711,0,0,1,.01-.869c.2-1.059.69-2.705.685-2.762,0-.031.092-.317-.317-.465a.508.508,0,0,0-.578.1c-.036,0-.061.087-.061.087s.445-1.851-.849-1.851a3.855,3.855,0,0,0-2.475,1.683c-.348.189-1.089.593-1.882,1.028-.3.169-.614.338-.905.5-.02-.02-.041-.046-.061-.066C6.87,17.6,3.975,16.416,4.1,14.171c.046-.818.327-2.966,5.559-5.575,4.306-2.122,7.733-1.534,8.326-.23.849,1.862-1.836,5.319-6.285,5.82a3.351,3.351,0,0,1-2.813-.711c-.235-.256-.271-.271-.358-.22-.143.077-.051.307,0,.44a2.626,2.626,0,0,0,1.606,1.263,8.55,8.55,0,0,0,5.217-.517c2.7-1.043,4.8-3.943,4.184-6.372-.619-2.465-4.71-3.278-8.582-1.9A19.5,19.5,0,0,0,4.359,9.952c-2.133,1.995-2.47,3.728-2.332,4.455.5,2.578,4.051,4.255,5.472,5.5-.072.041-.138.077-.194.107-.711.353-3.421,1.77-4.1,3.268-.767,1.7.123,2.915.711,3.079a4.374,4.374,0,0,0,4.71-1.908A4.725,4.725,0,0,0,9.049,20.1a.107.107,0,0,0-.02-.031l.557-.327c.363-.215.721-.414,1.028-.578a6.74,6.74,0,0,0-.363,1.862,3.886,3.886,0,0,0,.834,2.7.921.921,0,0,0,.675.22c.6,0,.875-.5,1.176-1.094.368-.726.7-1.57.7-1.57s-.414,2.281.711,2.281c.409,0,.823-.532,1.008-.8v.005s.01-.015.031-.051l.066-.107v-.01c.164-.286.532-.936,1.079-2.015.706-1.391,1.386-3.13,1.386-3.13a8.888,8.888,0,0,0,.271,1.13,10.643,10.643,0,0,0,.583,1.309c-.164.23-.266.358-.266.358l.005.005c-.133.174-.276.363-.435.547a16.3,16.3,0,0,0-1.314,1.647.447.447,0,0,0,.123.6,1.116,1.116,0,0,0,.685.113,3.147,3.147,0,0,0,1.028-.235,3.45,3.45,0,0,0,.885-.465,1.98,1.98,0,0,0,.849-1.744,3.521,3.521,0,0,0-.322-1.233c.051-.072.1-.143.148-.2... (truncated)" style="fill:#cd6799"></path>
					</svg>
					<h2>SASS</h2>
				</li>
			</ul>
			<ul class="link-cards">
				<li class="link-cards">
					<svg width="800px" height="800px" viewBox="0 0 32 32" fill="none">
						<path d="M18.6789 15.9759C18.6789 14.5415 17.4796 13.3785 16 13.3785C14.5206 13.3785 13.3211 14.5415 13.3211 15.9759C13.3211 17.4105 14.5206 18.5734 16 18.5734C17.4796 18.5734 18.6789 17.4105 18.6789 15.9759Z" fill="#53C1DE"></path>
						<path fill-rule="evenodd" clip-rule="evenodd" d="M24.7004 11.1537C25.2661 8.92478 25.9772 4.79148 23.4704 3.39016C20.9753 1.99495 17.7284 4.66843 16.0139 6.27318C14.3044 4.68442 10.9663 2.02237 8.46163 3.42814C5.96751 4.82803 6.73664 8.8928 7.3149 11.1357C4.98831 11.7764 1 13.1564 1 15.9759C1 18.7874 4.98416 20.2888 7.29698 20.9289C6.71658 23.1842 5.98596 27.1909 8.48327 28.5877C10.9973 29.9932 14.325 27.3945 16.0554 25.7722C17.7809 27.3864 20.9966 30.0021 23.4922 28.6014C25.9956 27.1963 25.3436 23.1184 24.7653 20.8625C27.0073 20.221 31 18.7523 31 15.9759C31 13.1835 26.9903 11.7923 24.7004 11.1537ZM24.4162 19.667C24.0365 18.5016 23.524 17.2623 22.8971 15.9821C23.4955 14.7321 23.9881 13.5088 24.3572 12.3509C26.0359 12.8228 29.7185 13.9013 29.7185 15.9759C29.7185 18.07 26.1846 19.1587 24.4162 19.667ZM22.85 27.526C20.988 28.571 18.2221 26.0696 16.9478 24.8809C17.7932 23.9844 18.638 22.9422 19.4625 21.7849C20.9129 21.6602 22.283 21.4562 23.5256 21.1777C23.9326 22.7734 24.7202 26.4763 22.85 27.526ZM9.12362 27.5111C7.26143 26.47 8.11258 22.8946 8.53957 21.2333C9.76834 21.4969 11.1286 21.6865 12.5824 21.8008C13.4123 22.9332 14.2816 23.9741 15.1576 24.8857C14.0753 25.9008 10.9945 28.557 9.12362 27.5111ZM2.28149 15.9759C2.28149 13.874 5.94207 12.8033 7.65904 12.3326C8.03451 13.5165 8.52695 14.7544 9.12123 16.0062C8.51925 17.2766 8.01977 18.5341 7.64085 19.732C6.00369 19.2776 2.28149 18.0791 2.28149 15.9759ZM9.1037 4.50354C10.9735 3.45416 13.8747 6.00983 15.1159 7.16013C14.2444 8.06754 13.3831 9.1006 12.5603 10.2265C11.1494 10.3533 9.79875 10.5569 8.55709 10.8297C8.09125 9.02071 7.23592 5.55179 9.1037 4.50354Z" fill="#53C1DE"></path>
					</svg>
					<h2>React.js</h2>
				</li>
			</ul>
			<ul class="link-cards">
				<li class="link-cards">
					<svg width="800px" height="800px" viewBox="0 0 32 32" fill="none">
						<path d="M16 2L0 18h7l-3 12 16-16H13l3-12z" fill="#339933"></path>
						<path d="M16 30l16-16h-7l3-12-16 16h7l-3 12z" fill="#339933"></path>
					</svg>
					<h2>Node.JS</h2>
				</li>
			</ul>
			<ul class="link-cards">
				<li class="link-cards">
					<svg width="800px" height="800px" viewBox="0 0 32 32" fill="none">
						<ellipse cx="16" cy="16" rx="14" ry="8" stroke="#00758F" stroke-width="2" fill="none"></ellipse>
						<path d="M16 8c-2 4-2 12 0 16" stroke="#00758F" stroke-width="2"></path>
					</svg>
					<h2>MySQL</h2>
				</li>
			</ul>
			<ul class="link-cards">
				<li class="link-cards">
					<svg width="800px" height="800px" viewBox="0 0 32 32" fill="none">
						<rect x="2" y="6" width="28" height="20" rx="2" fill="#336791"></rect>
						<path d="M16 6v20M2 16h28" stroke="#fff" stroke-width="2"></path>
					</svg>
					<h2>PostgreSQL</h2>
				</li>
			</ul>
			<ul class="link-cards">
				<li class="link-cards">
					<svg width="800px" height="800px" viewBox="0 0 32 32" fill="none">
						<rect width="32" height="32" rx="4" fill="#31A8FF"></rect>
						<path d="M8 8h16v16H8z" fill="#fff"></path>
					</svg>
					<h2>Adobe Photoshop</h2>
				</li>
			</ul>
			<ul class="link-cards">
				<li class="link-cards">
					<svg width="800px" height="800px" viewBox="0 0 32 32" fill="none">
						<rect width="32" height="32" rx="4" fill="#FF9A00"></rect>
						<path d="M8 24L24 8" stroke="#fff" stroke-width="2"></path>
					</svg>
					<h2>Adobe Illustrator</h2>
				</li>
			</ul>
			<ul class="link-cards">
				<li class="link-cards">
					<svg width="800px" height="800px" viewBox="0 0 32 32" fill="none">
						<rect width="32" height="32" rx="4" fill="#FF61F6"></rect>
						<circle cx="16" cy="16" r="8" fill="#fff"></circle>
					</svg>
					<h2>Adobe XD</h2>
				</li>
			</ul>
			<ul class="link-cards">
				<li class="link-cards">
					<svg width="800px" height="800px" viewBox="0 0 32 32">
						<path fill-rule="evenodd" clip-rule="evenodd" d="M16 0C7.163 0 0 7.163 0 16s7.163 16 16 16 16-7.163 16-16S24.837 0 16 0zm0 2c7.732 0 14 6.268 14 14s-6.268 14-14 14S2 23.732 2 16 8.268 2 16 2z" fill="#fff"></path>
					</svg>
					<h2>GitHub</h2>
				</li>
			</ul>
			<ul class="link-cards">
				<li class="link-cards">
					<svg width="800px" height="800px" viewBox="0 0 32 32">
						<circle cx="16" cy="16" r="14" fill="#F05032"></circle>
						<path d="M16 6l-10 10 3 3 7-7m0 0l7 7 3 3 3-10" stroke="#fff" stroke-width="2" fill="none"></path>
					</svg>
					<h2>Git</h2>
				</li>
			</ul>
		</div>
	</section>
</Layout>

<Footer>
	<slot />
</Footer>

<style>
	section {
		margin: 0 calc(100% - 86%);
	}
	h1 {
		display: grid;
		color: rgb(178, 179, 180);
		margin: 3rem 0;
		font-size: 4rem;
	}
	h2 {
		display: inline-block;
	}
	div {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(24ch, 1fr));
		gap: 2rem;
	}
	li {
		list-style: none;
		display: flex;
		flex-direction: column;
		align-items: center;
		padding: 1px;
		color: rgb(178, 179, 180);
		background-color: rgba(30, 27, 31, 0.8);
		background-image: none;
		background-size: 400%;
		border-radius: 7px;
		background-position: 50%;
		transition: background-position 2s cubic-bezier(0.22, 1, 0.36, 1);
		box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.1);
	}
	li > a {
		width: 100%;
		text-decoration: none;
		line-height: 1.4;
		padding: calc(1.5rem - 1px);
		border-radius: 8px;
		color: rgb(178, 179, 180);
		opacity: 0.8;
	}
	li:is(:hover, :focus-within) {
		background-position: 0;
		background-image: var(--accent-gradient);
	}
	li:is(:hover, :focus-within) h2 {
		color: #23262d;
	}

	svg {
		height: 100%;
		width: 100%;
		filter: grayscale(100%);
		transition: filter 0.3s ease;
	}
	svg:hover {
		filter: grayscale(0%);
	}
</style>
